{
  "name": "marketlab",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=24.15.0 <25",
    "bun": ">=1.3.13"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "test": "vitest",
    "test:run": "vitest run",
    "db:link": "supabase link --project-ref $SUPABASE_PROJECT_REF",
    "db:push": "supabase db push --include-seed",
    "db:types": "mkdir -p src/lib/supabase && supabase gen types typescript --project-id $SUPABASE_PROJECT_REF > src/lib/supabase/database.types.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "^16.2.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@tailwindcss/postcss": "^4",
    "@types/node": "24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "shadcn": "^4.6.0",
    "supabase": "^2.98.0",
    "tailwindcss": "^4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "core-js",
    "esbuild",
    "msw",
    "protobufjs",
    "sharp",
    "supabase",
    "unrs-resolver"
  ]
}
